# Optional: leave blank to use Collector Crypt public site pricing fallback.
COLLECTOR_CRYPT_API_KEY=
# You can provide one or multiple Solana mainnet RPC URLs separated by commas.
# The app will try them in order and automatically fail over to the next one.
SOLANA_RPC_URL=https://api.mainnet.solana.com,https://api.mainnet-beta.solana.com
COLLECTOR_CRYPT_CODES=pokemon_50,pokemon_250
COLLECTOR_CRYPT_COLLECTION_HINTS=Collector Crypt,Collector Crypt: Pokemon
